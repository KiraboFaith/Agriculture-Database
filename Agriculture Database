CREATE DATABASE IF NOT EXISTS agriculture_database;
USE agriculture_database;


-- LOCATION TABLES

CREATE TABLE REGION (
    Region_ID   INT PRIMARY KEY AUTO_INCREMENT,
    Region_name VARCHAR(100) NOT NULL
);

CREATE TABLE DISTRICT (
    District_ID   INT PRIMARY KEY AUTO_INCREMENT,
    District_name VARCHAR(100) NOT NULL,
    Region_ID     INT NOT NULL,
    FOREIGN KEY (Region_ID) REFERENCES REGION(Region_ID)
);

CREATE TABLE SUBCOUNTY (
    Subcounty_ID   INT PRIMARY KEY AUTO_INCREMENT,
    Subcounty_name VARCHAR(100) NOT NULL,
    District_ID    INT NOT NULL,
    FOREIGN KEY (District_ID) REFERENCES DISTRICT(District_ID)
);

CREATE TABLE VILLAGE (
    Village_ID   INT PRIMARY KEY AUTO_INCREMENT,
    Village_name VARCHAR(100) NOT NULL,
    Subcounty_ID INT NOT NULL,
    FOREIGN KEY (Subcounty_ID) REFERENCES SUBCOUNTY(Subcounty_ID)
);


-- PERSON (Supertype)

CREATE TABLE PERSON (
    Person_ID   INT PRIMARY KEY AUTO_INCREMENT,
    Name        VARCHAR(150) NOT NULL,
    NIN         VARCHAR(20)  NOT NULL UNIQUE,
    Gender      ENUM('Male','Female','Other'),
    Phone_no    VARCHAR(15),
    Email       VARCHAR(100),
    Address     VARCHAR(200),
    Village_ID  INT,
    Person_type ENUM('Farmer','Extension_Worker','Ministry_Staff','System_Admin') NOT NULL,
    FOREIGN KEY (Village_ID) REFERENCES VILLAGE(Village_ID)
);


-- SUBTYPES

CREATE TABLE FARMER (
    Farmer_ID  INT PRIMARY KEY AUTO_INCREMENT,
    Person_ID  INT NOT NULL UNIQUE,
    Reg_Date   DATE,
    Reg_Number VARCHAR(50) UNIQUE,
    FOREIGN KEY (Person_ID) REFERENCES PERSON(Person_ID)
);

CREATE TABLE EXTENSION_WORKER (
    Ext_ID        INT PRIMARY KEY AUTO_INCREMENT,
    Person_ID     INT NOT NULL UNIQUE,
    Qualification VARCHAR(100),
    Hire_Date     DATE,
    Status        ENUM('Active','Inactive') DEFAULT 'Active',
    Village_ID    INT,
    FOREIGN KEY (Person_ID)  REFERENCES PERSON(Person_ID),
    FOREIGN KEY (Village_ID) REFERENCES VILLAGE(Village_ID)
);

CREATE TABLE MINISTRY_STAFF (
    Staff_ID     INT PRIMARY KEY AUTO_INCREMENT,
    Person_ID    INT NOT NULL UNIQUE,
    Role         VARCHAR(100),
    Access_level VARCHAR(50),
    Hire_Date    DATE,
    FOREIGN KEY (Person_ID) REFERENCES PERSON(Person_ID)
);

CREATE TABLE SYSTEM_ADMIN (
    Admin_ID      INT PRIMARY KEY AUTO_INCREMENT,
    Person_ID     INT NOT NULL UNIQUE,
    Access_level  VARCHAR(50),
    Status        ENUM('Active','Inactive') DEFAULT 'Active',
    Username      VARCHAR(50)  NOT NULL UNIQUE,
    Password_hash VARCHAR(255) NOT NULL,
    FOREIGN KEY (Person_ID) REFERENCES PERSON(Person_ID)
);

CREATE TABLE ADMIN_ACTIVITY (
    Activity_ID      INT PRIMARY KEY AUTO_INCREMENT,
    Name             VARCHAR(150),
    Date_carried_out DATETIME DEFAULT CURRENT_TIMESTAMP,
    Activity         VARCHAR(255) NOT NULL,
    Table_Name       VARCHAR(100),
    Admin_ID         INT NOT NULL,
    FOREIGN KEY (Admin_ID) REFERENCES SYSTEM_ADMIN(Admin_ID)
);


-- CORE TABLES

CREATE TABLE PRODUCT (
    Product_ID   INT PRIMARY KEY AUTO_INCREMENT,
    Product_Type VARCHAR(100) NOT NULL,
    Product_Name VARCHAR(150) NOT NULL,
    Quantity     INT DEFAULT 0 CHECK (Quantity >= 0)
);

CREATE TABLE PLOT_FARM (
    Plot_ID     INT PRIMARY KEY AUTO_INCREMENT,
    PlotName    VARCHAR(100),
    Size_Acres  DECIMAL(10,2) NOT NULL CHECK (Size_Acres > 0),
    Coffee_type VARCHAR(100),
    Start_Year  YEAR,
    Farmer_ID   INT NOT NULL,
    Village_ID  INT,
    FOREIGN KEY (Farmer_ID)  REFERENCES FARMER(Farmer_ID),
    FOREIGN KEY (Village_ID) REFERENCES VILLAGE(Village_ID)
);

CREATE TABLE FARM_VISIT (
    Visit_ID       INT PRIMARY KEY AUTO_INCREMENT,
    Purpose        VARCHAR(255) NOT NULL,
    Visit_Date     DATE NOT NULL,
    Status         ENUM('Scheduled','Completed','Cancelled') DEFAULT 'Scheduled',
    Feedback       TEXT,
    Follow_up_Date DATE,
    Ext_ID         INT NOT NULL,
    Farmer_ID      INT NOT NULL,
    Plot_ID        INT,
    FOREIGN KEY (Ext_ID)    REFERENCES EXTENSION_WORKER(Ext_ID),
    FOREIGN KEY (Farmer_ID) REFERENCES FARMER(Farmer_ID),
    FOREIGN KEY (Plot_ID)   REFERENCES PLOT_FARM(Plot_ID)
);

CREATE TABLE SUPPORT_REQUEST (
    Request_ID   INT PRIMARY KEY AUTO_INCREMENT,
    Request_type VARCHAR(100) NOT NULL,
    Description  VARCHAR(255),
    Status       ENUM('Pending','In Progress','Resolved') DEFAULT 'Pending',
    Assigned_to  VARCHAR(100),
    Resolved_by  VARCHAR(100),
    Request_date DATE DEFAULT (CURRENT_DATE),
    Farmer_ID    INT NOT NULL,
    Worker_ID    INT,
    FOREIGN KEY (Farmer_ID) REFERENCES FARMER(Farmer_ID),
    FOREIGN KEY (Worker_ID) REFERENCES EXTENSION_WORKER(Ext_ID)
);

CREATE TABLE PRODUCTION_RECORD (
    Production_ID INT PRIMARY KEY AUTO_INCREMENT,
    Season        VARCHAR(50) NOT NULL,
    Harvest_Date  DATE,
    Quantity      DECIMAL(10,2) NOT NULL CHECK (Quantity > 0),
    Year          YEAR NOT NULL,
    Plot_ID       INT NOT NULL,
    FOREIGN KEY (Plot_ID) REFERENCES PLOT_FARM(Plot_ID)
);

CREATE TABLE DISTRIBUTION (
    Distribution_ID   INT PRIMARY KEY AUTO_INCREMENT,
    Product_Type      VARCHAR(100),
    Distribution_Date DATE NOT NULL,
    Farmer_ID         INT NOT NULL,
    Plot_ID           INT,
    Product_ID        INT NOT NULL,
    Staff_ID          INT,
    Ext_ID            INT,
    FOREIGN KEY (Farmer_ID)  REFERENCES FARMER(Farmer_ID),
    FOREIGN KEY (Plot_ID)    REFERENCES PLOT_FARM(Plot_ID),
    FOREIGN KEY (Product_ID) REFERENCES PRODUCT(Product_ID),
    FOREIGN KEY (Staff_ID)   REFERENCES MINISTRY_STAFF(Staff_ID),
    FOREIGN KEY (Ext_ID)     REFERENCES EXTENSION_WORKER(Ext_ID)
);


