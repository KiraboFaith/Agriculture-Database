-- VIEWS

CREATE VIEW view_farmer_location AS
SELECT f.Farmer_ID, p.Name AS Farmer_Name, p.Phone_no, p.Email,
       v.Village_name, sc.Subcounty_name, d.District_name, r.Region_name
FROM FARMER f
JOIN PERSON p          ON f.Person_ID    = p.Person_ID
LEFT JOIN VILLAGE v    ON p.Village_ID   = v.Village_ID
LEFT JOIN SUBCOUNTY sc ON v.Subcounty_ID = sc.Subcounty_ID
LEFT JOIN DISTRICT d   ON sc.District_ID = d.District_ID
LEFT JOIN REGION r     ON d.Region_ID    = r.Region_ID;

CREATE VIEW view_production_summary AS
SELECT f.Farmer_ID, p.Name AS Farmer_Name, pf.PlotName, pf.Coffee_type,
       pr.Season, pr.Year, SUM(pr.Quantity) AS Total_kg
FROM PRODUCTION_RECORD pr
JOIN PLOT_FARM pf ON pr.Plot_ID   = pf.Plot_ID
JOIN FARMER f     ON pf.Farmer_ID = f.Farmer_ID
JOIN PERSON p     ON f.Person_ID  = p.Person_ID
GROUP BY f.Farmer_ID, p.Name, pf.PlotName, pf.Coffee_type, pr.Season, pr.Year;

CREATE VIEW view_open_requests AS
SELECT sr.Request_ID, fp.Name AS Farmer_Name, sr.Request_type,
       sr.Request_date, sr.Status, sr.Description, sr.Assigned_to
FROM SUPPORT_REQUEST sr
JOIN FARMER f  ON sr.Farmer_ID = f.Farmer_ID
JOIN PERSON fp ON f.Person_ID  = fp.Person_ID
WHERE sr.Status != 'Resolved';

CREATE VIEW view_distribution_report AS
SELECT d.Distribution_ID, fp.Name AS Farmer_Name, pr.Product_Name,
       pr.Product_Type, d.Distribution_Date, sp.Name AS Distributed_By
FROM DISTRIBUTION d
JOIN FARMER f             ON d.Farmer_ID  = f.Farmer_ID
JOIN PERSON fp            ON f.Person_ID  = fp.Person_ID
JOIN PRODUCT pr           ON d.Product_ID = pr.Product_ID
LEFT JOIN MINISTRY_STAFF ms ON d.Staff_ID   = ms.Staff_ID
LEFT JOIN PERSON sp       ON ms.Person_ID = sp.Person_ID;


-- STORED PROCEDURES

DELIMITER $$

CREATE PROCEDURE procedure_registerfarmer(
    IN p_name VARCHAR(150), IN p_nin VARCHAR(20), IN p_phone VARCHAR(15),
    IN p_email VARCHAR(100), IN p_address VARCHAR(200), IN p_village_id INT
)
BEGIN
    DECLARE v_person_id INT;
    INSERT INTO PERSON (Name, NIN, Phone_no, Email, Address, Village_ID, Person_type)
    VALUES (p_name, p_nin, p_phone, p_email, p_address, p_village_id, 'Farmer');
    SET v_person_id = LAST_INSERT_ID();
    INSERT INTO FARMER (Person_ID, Reg_Date) VALUES (v_person_id, CURRENT_DATE);
    SELECT LAST_INSERT_ID() AS New_Farmer_ID;
END$$

CREATE PROCEDURE procedure_addproduction(
    IN p_plot_id INT, IN p_season VARCHAR(50), IN p_year YEAR,
    IN p_harvest DATE, IN p_quantity DECIMAL(10,2)
)
BEGIN
    INSERT INTO PRODUCTION_RECORD (Season, Harvest_Date, Quantity, Year, Plot_ID)
    VALUES (p_season, p_harvest, p_quantity, p_year, p_plot_id);
    SELECT 'Production record added successfully' AS Message;
END$$

CREATE PROCEDURE procedure_assignworker(IN p_request_id INT, IN p_worker_id INT)
BEGIN
    UPDATE SUPPORT_REQUEST
    SET Worker_ID   = p_worker_id,
        Status      = 'In Progress',
        Assigned_to = (SELECT p.Name FROM EXTENSION_WORKER ew
                       JOIN PERSON p ON ew.Person_ID = p.Person_ID
                       WHERE ew.Ext_ID = p_worker_id)
    WHERE Request_ID = p_request_id AND Status = 'Pending';
    IF ROW_COUNT() = 0 THEN
        SELECT 'Request not found or already assigned' AS Message;
    ELSE
        SELECT 'Worker assigned successfully' AS Message;
    END IF;
END$$

CREATE PROCEDURE procedure_farmerreport(IN p_farmer_id INT)
BEGIN
    SELECT p.Name, p.Phone_no, p.Email, p.Address, v.Village_name, d.District_name
    FROM FARMER f
    JOIN PERSON p          ON f.Person_ID    = p.Person_ID
    LEFT JOIN VILLAGE v    ON p.Village_ID   = v.Village_ID
    LEFT JOIN SUBCOUNTY sc ON v.Subcounty_ID = sc.Subcounty_ID
    LEFT JOIN DISTRICT d   ON sc.District_ID = d.District_ID
    WHERE f.Farmer_ID = p_farmer_id;

    SELECT PlotName, Size_Acres, Coffee_type, Start_Year
    FROM PLOT_FARM WHERE Farmer_ID = p_farmer_id;

    SELECT pr.Season, pr.Year, pr.Harvest_Date, pr.Quantity, pf.PlotName
    FROM PRODUCTION_RECORD pr
    JOIN PLOT_FARM pf ON pr.Plot_ID = pf.Plot_ID
    WHERE pf.Farmer_ID = p_farmer_id;

    SELECT Request_type, Request_date, Status, Description
    FROM SUPPORT_REQUEST WHERE Farmer_ID = p_farmer_id;
END$$

DELIMITER ;


-- TRIGGERS

DELIMITER $$

CREATE TRIGGER trigger_prevent_duplicate_production
BEFORE INSERT ON PRODUCTION_RECORD
FOR EACH ROW
BEGIN
    DECLARE v_count INT;
    SELECT COUNT(*) INTO v_count FROM PRODUCTION_RECORD
    WHERE Plot_ID = NEW.Plot_ID AND Season = NEW.Season AND Year = NEW.Year;
    IF v_count > 0 THEN
        SIGNAL SQLSTATE '45000'
        SET MESSAGE_TEXT = 'Duplicate: a production record for this plot, season and year already exists.';
    END IF;
END$$

CREATE TRIGGER trigger_validate_plot_size
BEFORE UPDATE ON PLOT_FARM
FOR EACH ROW
BEGIN
    IF NEW.Size_Acres <= 0 THEN
        SIGNAL SQLSTATE '45000'
        SET MESSAGE_TEXT = 'Plot size must be greater than zero.';
    END IF;
END$$

CREATE TRIGGER trigger_check_visit_date
BEFORE INSERT ON FARM_VISIT
FOR EACH ROW
BEGIN
    IF NEW.Visit_Date < DATE_SUB(CURRENT_DATE, INTERVAL 1 YEAR) THEN
        SIGNAL SQLSTATE '45000'
        SET MESSAGE_TEXT = 'Visit date cannot be more than 1 year in the past.';
    END IF;
END$$

CREATE TRIGGER trigger_log_admin_activity
AFTER INSERT ON DISTRIBUTION
FOR EACH ROW
BEGIN
    INSERT INTO ADMIN_ACTIVITY (Name, Activity, Table_Name, Admin_ID)
    SELECT 'Distribution Logged',
           CONCAT('New distribution ID ', NEW.Distribution_ID, ' added'),
           'DISTRIBUTION', Admin_ID
    FROM SYSTEM_ADMIN LIMIT 1;
END$$

DELIMITER ;


